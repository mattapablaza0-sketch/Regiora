<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Regiora — Journeys, Bottled</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Manrope:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#0f2a3a;          /* deep ocean blue */
    --ink-soft:#1c3f52;
    --sand:#e7d8bd;         /* warm sandy tone */
    --sand-deep:#c9a876;    /* sand-gold accent */
    --moss:#4b5d45;         /* lush green */
    --moss-deep:#374530;
    --white:#faf8f3;        /* crisp white */
    --paper:#fffdf9;
    --line: rgba(15,42,58,0.14);
    --shadow: 0 20px 60px rgba(15,42,58,0.18);
    --ease: cubic-bezier(.16,.84,.44,1);
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  html{scroll-behavior:smooth;}
  body{
    background:var(--white);
    color:var(--ink);
    font-family:'Manrope', sans-serif;
    font-weight:400;
    overflow-x:hidden;
    -webkit-font-smoothing:antialiased;
  }
  h1,h2,h3,.serif{font-family:'Fraunces', serif;}
  a{color:inherit; text-decoration:none;}
  button{font-family:inherit; cursor:pointer; border:none; background:none;}
  img{display:block; max-width:100%;}
  .eyebrow{
    font-size:0.72rem; letter-spacing:.22em; text-transform:uppercase;
    font-weight:600; color:var(--sand-deep);
  }
  ::selection{background:var(--sand-deep); color:var(--white);}
  :focus-visible{outline:2px solid var(--sand-deep); outline-offset:3px;}

  /* reveal on scroll */
  .reveal{opacity:0; transform:translateY(28px); transition:opacity .9s var(--ease), transform .9s var(--ease);}
  .reveal.visible{opacity:1; transform:translateY(0);}

  /* ================= NAV ================= */
  header{
    position:fixed; top:0; left:0; right:0; z-index:500;
    padding:26px 40px;
    display:flex; align-items:center; justify-content:space-between;
    transition: padding .4s var(--ease), background .4s var(--ease), box-shadow .4s var(--ease);
  }
  header.scrolled{
    padding:14px 40px;
    background:rgba(250,248,243,0.88);
    backdrop-filter:blur(14px);
    box-shadow:0 1px 0 var(--line);
  }
  header .side{display:flex; align-items:center; gap:34px; flex:1;}
  header .side.right{justify-content:flex-end;}
  nav ul{list-style:none; display:flex; gap:34px;}
  nav a{
    font-size:0.82rem; letter-spacing:.08em; text-transform:uppercase; font-weight:600;
    color:var(--white); position:relative; padding-bottom:4px;
    transition:color .4s;
  }
  header.scrolled nav a{color:var(--ink);}
  nav a::after{
    content:''; position:absolute; left:0; bottom:0; width:0; height:1px;
    background:currentColor; transition:width .35s var(--ease);
  }
  nav a:hover::after{width:100%;}
  .logo{
    font-family:'Fraunces', serif; font-size:1.7rem; font-weight:500;
    letter-spacing:.03em; color:var(--white); transition:color .4s;
    white-space:nowrap;
  }
  header.scrolled .logo{color:var(--ink);}
  .icon-btn{
    background:none; border:none; color:var(--white); position:relative;
    display:flex; align-items:center; gap:6px; transition:color .4s;
  }
  header.scrolled .icon-btn{color:var(--ink);}
  .cart-count{
    position:absolute; top:-8px; right:-12px; background:var(--sand-deep); color:var(--white);
    font-size:.65rem; font-weight:700; width:17px; height:17px; border-radius:50%;
    display:flex; align-items:center; justify-content:center;
  }
  .hamburger{display:none; background:none; border:none; color:var(--white);}
  header.scrolled .hamburger{color:var(--ink);}

  /* ================= HERO ================= */
  .hero{
    position:relative; height:100svh; min-height:560px; width:100%;
    display:flex; align-items:flex-end; justify-content:center;
    overflow:hidden;
  }
  .hero-bg{
    position:absolute; inset:0; background-size:cover; background-position:center;
    transform:scale(1.08); animation:heroPan 22s ease-in-out infinite alternate;
  }
  @keyframes heroPan{ from{transform:scale(1.08) translateX(0);} to{transform:scale(1.14) translateX(-1.5%);} }
  .hero::before{
    content:''; position:absolute; inset:0;
    background:linear-gradient(180deg, rgba(15,42,58,.35) 0%, rgba(15,42,58,.12) 32%, rgba(15,42,58,.55) 100%);
    z-index:1;
  }
  .hero-content{
    position:relative; z-index:2; text-align:center; color:var(--white);
    padding-bottom:9vh; max-width:800px; margin:0 auto; padding-left:24px; padding-right:24px;
  }
  .hero-content .eyebrow{color:var(--sand); opacity:0; animation:fadeUp 1.1s .3s var(--ease) forwards;}
  .hero-content h1{
    font-size:clamp(2.8rem, 7vw, 5.6rem); font-weight:400; line-height:1.02; margin:14px 0 18px;
    letter-spacing:-.01em;
    opacity:0; animation:fadeUp 1.2s .5s var(--ease) forwards;
  }
  .hero-content p{
    font-size:1.08rem; font-weight:300; max-width:520px; margin:0 auto 34px; line-height:1.6;
    color:rgba(250,248,243,.92);
    opacity:0; animation:fadeUp 1.2s .75s var(--ease) forwards;
  }
  @keyframes fadeUp{ from{opacity:0; transform:translateY(18px);} to{opacity:1; transform:translateY(0);} }
  .btn{
    display:inline-flex; align-items:center; gap:10px; padding:15px 34px;
    font-size:.78rem; letter-spacing:.14em; text-transform:uppercase; font-weight:700;
    border-radius:2px; transition:all .35s var(--ease);
  }
  .btn-primary{background:var(--white); color:var(--ink);}
  .btn-primary:hover{background:var(--sand-deep); color:var(--white); letter-spacing:.18em;}
  .btn-outline{border:1px solid rgba(255,255,255,.65); color:var(--white);}
  .btn-outline:hover{background:rgba(255,255,255,.12); border-color:#fff;}
  .btn-dark{background:var(--ink); color:var(--white);}
  .btn-dark:hover{background:var(--moss-deep);}
  .btn-ghost-dark{border:1px solid var(--ink); color:var(--ink);}
  .btn-ghost-dark:hover{background:var(--ink); color:var(--white);}
  .hero-cta{
    opacity:0; animation:fadeUp 1.2s 1s var(--ease) forwards;
    display:flex; gap:16px; justify-content:center; flex-wrap:wrap;
  }
  .scroll-cue{
    position:absolute; bottom:26px; left:50%; transform:translateX(-50%); z-index:2;
    color:var(--white); font-size:.68rem; letter-spacing:.2em; text-transform:uppercase;
    display:flex; flex-direction:column; align-items:center; gap:8px; opacity:.85;
  }
  .scroll-cue .line{width:1px; height:34px; background:rgba(255,255,255,.6); position:relative; overflow:hidden;}
  .scroll-cue .line::after{content:''; position:absolute; top:-100%; left:0; width:100%; height:100%; background:#fff; animation:cueDrop 1.8s ease-in-out infinite;}
  @keyframes cueDrop{ to{top:100%;} }

  /* ================= MISSION ================= */
  .mission{
    padding:150px 24px; text-align:center; position:relative;
    background:var(--white);
  }
  .mission-inner{max-width:760px; margin:0 auto;}
  .mission h2{
    font-size:clamp(2rem, 4vw, 2.9rem); font-weight:400; line-height:1.25; margin:20px 0 26px; color:var(--ink);
  }
  .mission p{font-size:1.05rem; line-height:1.85; color:var(--ink-soft); font-weight:300; max-width:620px; margin:0 auto;}
  .mission .compass{
    width:54px; height:54px; margin:0 auto 22px; opacity:.85;
  }
  .stat-row{
    display:flex; justify-content:center; gap:70px; margin-top:64px; flex-wrap:wrap;
  }
  .stat{text-align:center;}
  .stat b{display:block; font-family:'Fraunces',serif; font-size:2.1rem; color:var(--sand-deep); font-weight:500;}
  .stat span{font-size:.72rem; letter-spacing:.12em; text-transform:uppercase; color:var(--ink-soft);}

  /* ================= PRODUCTS ================= */
  .shop{background:var(--ink); padding:130px 24px 150px; position:relative;}
  .shop-head{text-align:center; max-width:640px; margin:0 auto 80px;}
  .shop-head .eyebrow{color:var(--sand-deep);}
  .shop-head h2{color:var(--white); font-size:clamp(2rem,4vw,2.8rem); font-weight:400; margin:16px 0 18px;}
  .shop-head p{color:rgba(250,248,243,.72); font-weight:300; line-height:1.7;}

  .products{
    max-width:1240px; margin:0 auto; display:grid; grid-template-columns:repeat(3,1fr); gap:34px;
  }
  .ticket{
    background:var(--paper); border-radius:6px; overflow:hidden; position:relative;
    box-shadow:var(--shadow); transition:transform .55s var(--ease), box-shadow .55s var(--ease);
    display:flex; flex-direction:column;
  }
  .ticket:hover{transform:translateY(-10px); box-shadow:0 34px 80px rgba(0,0,0,.35);}
  .ticket-photo{
    height:280px; background-size:cover; background-position:center; position:relative;
  }
  .ticket-photo::after{content:''; position:absolute; inset:0; background:linear-gradient(180deg, rgba(15,42,58,0) 55%, rgba(15,42,58,.55) 100%);}
  .ticket-tag{
    position:absolute; top:18px; left:18px; z-index:2;
    background:rgba(250,248,243,.92); color:var(--ink);
    font-size:.66rem; letter-spacing:.14em; text-transform:uppercase; font-weight:700;
    padding:7px 12px; border-radius:2px;
  }
  .ticket-coords{
    position:absolute; bottom:16px; left:18px; z-index:2; color:var(--white);
    font-size:.7rem; letter-spacing:.08em; font-family:'Manrope'; opacity:.9;
  }
  .ticket-body{padding:28px 26px 30px; position:relative; flex:1; display:flex; flex-direction:column;}
  .ticket-body h3{font-size:1.5rem; font-weight:500; color:var(--ink); margin-bottom:4px;}
  .ticket-body .route{
    font-size:.68rem; letter-spacing:.14em; text-transform:uppercase; color:var(--sand-deep); font-weight:700; margin-bottom:14px;
  }
  .ticket-body p.desc{font-size:.9rem; line-height:1.7; color:var(--ink-soft); font-weight:400; margin-bottom:18px;}
  .perf{
    border-top:1px dashed var(--line); margin:6px 0 18px; position:relative;
  }
  .perf::before,.perf::after{
    content:''; position:absolute; top:-7px; width:14px; height:14px; border-radius:50%; background:var(--ink);
  }
  .perf::before{left:-26px;} .perf::after{right:-26px;}
  .notes{display:flex; flex-wrap:wrap; gap:8px; margin-bottom:22px;}
  .note-pill{
    font-size:.68rem; letter-spacing:.03em; padding:5px 11px; border:1px solid var(--line);
    border-radius:20px; color:var(--moss-deep); background:rgba(75,93,69,.06);
  }
  .sourced-tag{
    display:inline-flex; align-items:center; gap:6px; font-size:.68rem; letter-spacing:.06em;
    color:var(--moss-deep); font-weight:700; margin-bottom:14px;
  }
  .sourced-tag svg{flex-shrink:0;}
  .ticket-foot{margin-top:auto; display:flex; align-items:center; justify-content:space-between; gap:10px;}
  .price{font-family:'Fraunces',serif; font-size:1.3rem; color:var(--ink); font-weight:500;}
  .price span{font-size:.7rem; color:var(--ink-soft); font-weight:400; font-family:'Manrope';}
  .ticket-actions{display:flex; gap:10px; margin-top:18px;}
  .ticket-actions .btn{flex:1; padding:12px 14px; font-size:.7rem; justify-content:center;}

  /* ================= STORY STRIP ================= */
  .story{
    padding:150px 24px; background:var(--sand); position:relative; overflow:hidden;
  }
  .story-grid{
    max-width:1160px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:70px; align-items:center;
  }
  .story-photo{
    aspect-ratio:4/5; background-size:cover; background-position:center; border-radius:6px; box-shadow:var(--shadow);
  }
  .story-text .eyebrow{color:var(--moss-deep);}
  .story-text h2{font-size:clamp(1.9rem,3.6vw,2.6rem); font-weight:400; margin:18px 0 22px; color:var(--ink);}
  .story-text p{font-size:1rem; line-height:1.85; color:var(--ink-soft); font-weight:300; margin-bottom:16px;}

  /* ================= NEWSLETTER ================= */
  .newsletter{
    background:var(--moss); color:var(--white); padding:100px 24px; text-align:center;
  }
  .newsletter h2{font-size:clamp(1.7rem,3vw,2.3rem); font-weight:400; margin-bottom:14px;}
  .newsletter p{font-weight:300; opacity:.85; margin-bottom:32px;}
  .news-form{display:flex; max-width:440px; margin:0 auto; gap:10px; flex-wrap:wrap; justify-content:center;}
  .news-form input{
    flex:1; min-width:220px; padding:14px 18px; border:1px solid rgba(255,255,255,.4); background:transparent;
    color:var(--white); font-size:.88rem; border-radius:2px;
  }
  .news-form input::placeholder{color:rgba(255,255,255,.6);}
  .news-form button{
    padding:14px 28px; background:var(--white); color:var(--moss-deep); font-size:.74rem;
    letter-spacing:.12em; text-transform:uppercase; font-weight:700; border-radius:2px; transition:.3s;
  }
  .news-form button:hover{background:var(--sand);}

  /* ================= FOOTER ================= */
  footer{background:var(--ink); color:rgba(250,248,243,.7); padding:80px 24px 30px;}
  .footer-grid{
    max-width:1160px; margin:0 auto; display:grid; grid-template-columns:1.6fr 1fr 1fr 1fr; gap:50px; padding-bottom:60px;
    border-bottom:1px solid rgba(255,255,255,.1);
  }
  .footer-grid .logo{color:var(--white); margin-bottom:14px; display:block;}
  .footer-grid p{font-size:.88rem; line-height:1.7; font-weight:300; max-width:280px;}
  .footer-col h4{font-size:.72rem; letter-spacing:.14em; text-transform:uppercase; color:var(--sand); margin-bottom:18px; font-weight:700;}
  .footer-col ul{list-style:none;}
  .footer-col li{margin-bottom:11px; font-size:.88rem;}
  .footer-col a:hover{color:var(--white);}
  .footer-bottom{
    max-width:1160px; margin:0 auto; padding-top:26px; display:flex; justify-content:space-between;
    font-size:.76rem; flex-wrap:wrap; gap:10px; color:rgba(250,248,243,.5);
  }

  /* ================= CART DRAWER ================= */
  .overlay{
    position:fixed; inset:0; background:rgba(15,42,58,.45); backdrop-filter:blur(2px);
    opacity:0; pointer-events:none; transition:opacity .4s var(--ease); z-index:900;
  }
  .overlay.active{opacity:1; pointer-events:auto;}
  .drawer{
    position:fixed; top:0; right:0; height:100%; width:420px; max-width:92vw; background:var(--paper);
    z-index:950; transform:translateX(100%); transition:transform .5s var(--ease);
    display:flex; flex-direction:column; box-shadow:-10px 0 40px rgba(0,0,0,.2);
  }
  .drawer.active{transform:translateX(0);}
  .drawer-head{
    padding:26px 26px 20px; display:flex; align-items:center; justify-content:space-between; border-bottom:1px solid var(--line);
  }
  .drawer-head h3{font-size:1.2rem; font-weight:500;}
  .close-btn{font-size:1.4rem; color:var(--ink); line-height:1;}
  .drawer-body{flex:1; overflow-y:auto; padding:20px 26px;}
  .cart-item{display:flex; gap:14px; padding:16px 0; border-bottom:1px solid var(--line);}
  .cart-item img{width:70px; height:88px; object-fit:cover; border-radius:3px;}
  .cart-item-info{flex:1;}
  .cart-item-info h4{font-size:.95rem; font-weight:600; margin-bottom:3px;}
  .cart-item-info .r{font-size:.68rem; color:var(--sand-deep); text-transform:uppercase; letter-spacing:.08em; font-weight:700; margin-bottom:8px;}
  .qty-row{display:flex; align-items:center; gap:10px;}
  .qty-btn{width:24px; height:24px; border:1px solid var(--line); border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:.85rem;}
  .qty-btn:hover{background:var(--ink); color:var(--white); border-color:var(--ink);}
  .remove-btn{font-size:.72rem; text-decoration:underline; color:var(--ink-soft); margin-left:auto;}
  .cart-item .item-price{font-weight:600; font-size:.9rem; white-space:nowrap;}
  .empty-cart{text-align:center; padding:60px 20px; color:var(--ink-soft);}
  .drawer-foot{padding:22px 26px 28px; border-top:1px solid var(--line);}
  .subtotal-row{display:flex; justify-content:space-between; margin-bottom:16px; font-size:.95rem;}
  .subtotal-row b{font-family:'Fraunces',serif; font-size:1.2rem;}
  .drawer-foot .btn{width:100%; justify-content:center; padding:16px;}

  /* ================= CHECKOUT MODAL ================= */
  .modal{
    position:fixed; inset:0; z-index:1000; display:flex; align-items:center; justify-content:center;
    padding:24px; opacity:0; pointer-events:none; transition:opacity .35s var(--ease);
  }
  .modal.active{opacity:1; pointer-events:auto;}
  .modal-box{
    background:var(--paper); max-width:520px; width:100%; max-height:88vh; overflow-y:auto;
    border-radius:8px; padding:40px; position:relative; transform:translateY(20px); transition:transform .4s var(--ease);
    box-shadow:0 40px 100px rgba(0,0,0,.35);
  }
  .modal.active .modal-box{transform:translateY(0);}
  .modal-box h3{font-size:1.5rem; font-weight:500; margin-bottom:6px;}
  .modal-box .sub{font-size:.85rem; color:var(--ink-soft); margin-bottom:26px;}
  .modal-close{position:absolute; top:22px; right:24px; font-size:1.4rem; color:var(--ink-soft);}
  .form-row{display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:14px;}
  .field{margin-bottom:14px;}
  .field label{display:block; font-size:.72rem; letter-spacing:.06em; text-transform:uppercase; font-weight:700; color:var(--ink-soft); margin-bottom:6px;}
  .field input{
    width:100%; padding:12px 14px; border:1px solid var(--line); border-radius:4px; font-size:.9rem; font-family:inherit;
    background:var(--white); color:var(--ink);
  }
  .field input:focus{border-color:var(--sand-deep);}
  .order-summary{background:rgba(199,168,118,.08); border:1px solid var(--line); border-radius:6px; padding:16px 18px; margin:20px 0; font-size:.85rem;}
  .order-summary .line{display:flex; justify-content:space-between; margin-bottom:6px; color:var(--ink-soft);}
  .order-summary .total{display:flex; justify-content:space-between; font-weight:700; color:var(--ink); font-size:1rem; margin-top:10px; padding-top:10px; border-top:1px solid var(--line);}
  .modal .btn{width:100%; justify-content:center; padding:16px; margin-top:8px;}
  .confirm-view{text-align:center; padding:20px 0;}
  .confirm-icon{
    width:64px; height:64px; border-radius:50%; background:var(--moss); color:var(--white);
    display:flex; align-items:center; justify-content:center; margin:0 auto 22px; font-size:1.6rem;
  }
  .confirm-view h3{margin-bottom:10px;}
  .confirm-view p{color:var(--ink-soft); font-size:.92rem; line-height:1.6; margin-bottom:26px;}
  .confirm-code{
    font-family:'Fraunces',serif; letter-spacing:.08em; font-size:1.1rem; background:var(--sand);
    display:inline-block; padding:10px 22px; border-radius:4px; margin-bottom:26px;
  }

  /* toast */
  .toast{
    position:fixed; bottom:30px; left:50%; transform:translateX(-50%) translateY(20px);
    background:var(--ink); color:var(--white); padding:14px 26px; border-radius:40px; font-size:.85rem;
    z-index:1100; opacity:0; pointer-events:none; transition:all .4s var(--ease); display:flex; align-items:center; gap:10px;
  }
  .toast.active{opacity:1; transform:translateX(-50%) translateY(0);}

  /* mobile nav */
  .mobile-menu{
    position:fixed; inset:0; background:var(--ink); z-index:800; display:flex; flex-direction:column;
    align-items:center; justify-content:center; gap:28px; transform:translateY(-100%); transition:transform .5s var(--ease);
  }
  .mobile-menu.active{transform:translateY(0);}
  .mobile-menu a{color:var(--white); font-family:'Fraunces',serif; font-size:1.8rem;}
  .mobile-menu .close-btn{position:absolute; top:26px; right:30px; color:var(--white); font-size:2rem;}

  @media (max-width:980px){
    .products{grid-template-columns:1fr; max-width:460px;}
    .story-grid{grid-template-columns:1fr;}
    .footer-grid{grid-template-columns:1fr 1fr; gap:36px;}
    header nav, header .side .icon-btn.mail-hide{display:none;}
    .hamburger{display:block;}
    header{padding:20px;}
    header.scrolled{padding:12px 20px;}
  }
  @media (max-width:520px){
    .footer-grid{grid-template-columns:1fr;}
    .stat-row{gap:36px;}
    .mission,.shop,.story,.newsletter{padding-left:20px; padding-right:20px;}
  }
  @media (prefers-reduced-motion: reduce){
    *{animation-duration:.01ms !important; transition-duration:.01ms !important;}
  }
</style>
</head>
<body>

<!-- ================= HEADER ================= -->
<header id="siteHeader">
  <div class="side left">
    <nav><ul>
      <li><a href="#home">Home</a></li>
      <li><a href="#shop">Shop</a></li>
      <li><a href="#story">Our Story</a></li>
    </ul></nav>
  </div>
  <a href="#home" class="logo">REGIORA</a>
  <div class="side right">
    <nav><ul><li><a href="#contact">Contact</a></li></ul></nav>
    <button class="icon-btn" id="cartBtn" aria-label="Open cart" style="margin-left:28px;">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M6 6h15l-1.5 9h-12z"/><path d="M6 6L4.5 3H2"/><circle cx="9" cy="20" r="1.4" fill="currentColor" stroke="none"/><circle cx="17" cy="20" r="1.4" fill="currentColor" stroke="none"/></svg>
      <span class="cart-count" id="cartCount">0</span>
